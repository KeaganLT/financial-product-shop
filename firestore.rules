rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Credential vault — Admin SDK only, all client access denied ──────────
    match /credentialVault/{uid} {
      allow read, write: if false;
    }

    // ── Contracts — users can only read/write their own records ─────────────
    // Path: contracts/{customerId}/products/{productId}
    // We match customerId as a string; Firebase Auth UID is a string too but
    // in this app the legacy customerId (numeric string) is stored in auth context,
    // not the Firebase UID. We allow any authenticated user to write their own
    // subtree — the app only ever passes auth.customerId as the document path.
    match /contracts/{customerId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Bank accounts — saved debit accounts + per-product assignments
    match /bankAccounts/{customerId} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
