{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8085
    },
    "auth": {
      "port": 9099
    },
    "ui": {
      "enabled": true,
      "port": 4010
    },
    "hub": {
      "port": 4410
    },
    "logging": {
      "port": 4510
    }
  }
}
